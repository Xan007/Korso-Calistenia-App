{
  "expo": {
    "name": "Korso",
    "slug": "korso",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#000000"
    },
    "ios": {
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },
    "plugins": [
      "expo-font",
      "expo-status-bar",
      "expo-audio",
      "react-native-audio-api"
    ],
    "android": {
      "package": "com.xan007.korso"
    }
  }
}
